# ==========================================
# Python / Flask 项目 .gitignore
# ==========================================

# ------------------------------------------
# 环境变量文件 (包含敏感信息)
# ------------------------------------------
.env
.env.local
.env.development
.env.production

# ------------------------------------------
# Python
# ------------------------------------------
# 字节码文件
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
.eggs/
*.egg-info/
*.whl
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# VS Code
.vscode/*
!.vscode/extensions.json

# OS files
.pytest_cache/
.tox/

# ------------------------------------------
# 数据库
# ------------------------------------------
*.db
*.sqlite
*.sqlite3


# ------------------------------------------
# 系统文件
# ------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------
# 其他
# ------------------------------------------
.cache/
*.bak


# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# ------------------------------------------
# 日志和临时文件
# ------------------------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock